# Environment Configuration for KrishiAI

# Backend API URL
VITE_API_URL=http://localhost:8000

# Google Maps API Key (for land management)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeather API Key (for weather data)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Twilio API Keys (for SMS OTP)
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
VITE_TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Razorpay API Keys (for payments)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
VITE_RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# App Configuration
VITE_APP_NAME=KrishiAI
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered Farming Platform for Indian Farmers

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_PWA=false
