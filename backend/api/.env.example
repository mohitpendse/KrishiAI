# ============================================
# KrishiAI Backend Environment Configuration
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace placeholder values with your actual API keys
# 3. Generate SECRET_KEY: openssl rand -hex 32
# 4. Empty values are OK - features will use mock data
#
# ============================================

# Database Configuration
DATABASE_URL=sqlite:///./krishi_ai.db

# ============================================
# REQUIRED (for production)
# ============================================

# JWT Secret Key - Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters

# ============================================
# OPTIONAL API KEYS
# ============================================

# Google Maps API Key
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# OpenWeather API Key
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Twilio SMS Configuration
# Get from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay Payment Configuration
# Get from: https://razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ============================================
# NOTES:
# ============================================
# - All API keys are optional except SECRET_KEY (for production)
# - Empty values mean features will use mock data
# - The app will run fine without API keys
